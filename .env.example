# MVD Accessioning Workstation — Environment Variables
# Copy to .env and fill in values for your station

# Station identity
STATION_ID=DEV-01

# Azure APIM (gate checks + accession submit)
APIM_BASE_URL=https://mvd-apim.azure-api.net
APIM_SUBSCRIPTION_KEY=your-subscription-key-here

# Azure Blob Storage (data sync)
BLOB_CUSTOMER_SAS=https://mvdstorage.blob.core.windows.net/data/customer_master.json?sv=...
BLOB_PHYSICIAN_SAS=https://mvdstorage.blob.core.windows.net/data/physician_npi.json?sv=...

# Logging
LOG_LEVEL=INFO
